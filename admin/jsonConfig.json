{
  "i18n": false,
  "type": "panel",
  "items": {
    "_headerInput": {
      "type": "header",
      "size": 2,
      "text": {
        "en": "Input data",
        "de": "Eingangsdaten"
      }
    },
    "inputMode": {
      "type": "select",
      "label": {
        "en": "Input type of the datapoints",
        "de": "Eingabeart der Datenpunkte"
      },
      "help": {
        "en": "Power: momentary values in W. Meter reading: cumulative values in kWh.",
        "de": "Leistung: momentane Werte in W. Zählerstand: kumulierte Werte in kWh."
      },
      "options": [
        {
          "value": "power",
          "label": {
            "en": "Power (W, momentary)",
            "de": "Leistung (W, momentan)"
          }
        },
        {
          "value": "energy",
          "label": {
            "en": "Meter reading (kWh, cumulative)",
            "de": "Zählerstand (kWh, kumuliert)"
          }
        }
      ],
      "default": "power",
      "newLine": true,
      "sm": 12,
      "md": 6,
      "xs": 12,
      "lg": 6,
      "xl": 6
    },
    "sourceMode": {
      "type": "select",
      "label": {
        "en": "Data source",
        "de": "Datenquelle"
      },
      "help": {
        "en": "PV + consumption OR grid import + feed-in of a bidirectional meter.",
        "de": "PV + Verbrauch ODER Netzbezug + Einspeisung eines Zweirichtungszählers."
      },
      "options": [
        {
          "value": "pv_consumption",
          "label": {
            "en": "PV generation + house consumption",
            "de": "PV-Erzeugung + Hausverbrauch"
          }
        },
        {
          "value": "grid_meter",
          "label": {
            "en": "Grid import + feed-in (two datapoints)",
            "de": "Netzbezug + Einspeisung (zwei Datenpunkte)"
          }
        },
        {
          "value": "grid_signed",
          "label": {
            "en": "Grid – one signed datapoint (+/-)",
            "de": "Netz – ein Datenpunkt mit Vorzeichen (+/-)"
          }
        }
      ],
      "default": "pv_consumption",
      "sm": 12,
      "md": 6,
      "xs": 12,
      "lg": 6,
      "xl": 6
    },
    "idPv": {
      "type": "objectId",
      "label": {
        "en": "PV generation datapoint",
        "de": "Datenpunkt PV-Erzeugung"
