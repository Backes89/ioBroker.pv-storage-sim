{
  "i18n": true,
  "type": "panel",
  "items": {
    "_headerInput": {
      "type": "header",
      "size": 2,
      "text": "Eingangsdaten"
    },
    "inputMode": {
      "type": "select",
      "label": "Eingabeart der Datenpunkte",
      "help": "Leistung: momentane Werte in W. Zählerstand: kumulierte Werte in kWh.",
      "options": [
        { "value": "power", "label": "Leistung (W, momentan)" },
        { "value": "energy", "label": "Zählerstand (kWh, kumuliert)" }
      ],
      "default": "power",
      "newLine": true,
      "sm": 12,
      "md": 6
    },
    "sourceMode": {
      "type": "select",
      "label": "Datenquelle",
      "help": "PV + Verbrauch ODER Netzbezug + Einspeisung eines Zweirichtungszählers.",
      "options": [
        { "value": "pv_consumption", "label": "PV-Erzeugung + Hausverbrauch" },
        { "value": "grid_meter", "label": "Netzbezug + Einspeisung (zwei Datenpunkte)" },
        { "value": "grid_signed", "label": "Netz – ein Datenpunkt mit Vorzeichen (+/-)" }
      ],
      "default": "pv_consumption",
      "sm": 12,
      "md": 6
    },
    "idPv": {
      "type": "objectId",
      "label": "Datenpunkt PV-Erzeugung",
      "hidden": "data.sourceMode !== 'pv_consumption'",
      "newLine": true,
      "sm": 12,
      "md": 5
    },
    "unitPvPower": {
      "type": "select",
      "label": "Einheit",
      "options": [ { "value": "W", "label": "W" }, { "value": "kW", "label": "kW" } ],
      "default": "W",
      "hidden": "data.sourceMode !== 'pv_consumption' || data.inputMode !== 'power'",
      "sm": 12,
      "md": 3
    },
    "unitPvEnergy": {
      "type": "select",
      "label": "Einheit",
      "options": [ { "value": "kWh", "label": "kWh" }, { "value": "Wh", "label": "Wh" } ],
      "default": "kWh",
      "hidden": "data.sourceMode !== 'pv_consumption' || data.inputMode !== 'energy'",
      "sm": 12,
      "md": 3
    },
    "idConsumption": {
      "type": "objectId",
      "label": "Datenpunkt Hausverbrauch",
      "hidden": "data.sourceMode !== 'pv_consumption'",
      "newLine": true,
      "sm": 12,
      "md": 5
    },
    "unitConsumptionPower": {
      "type": "select",
      "label": "Einheit",
      "options": [ { "value": "W", "label": "W" }, { "value": "kW", "label": "kW" } ],
      "default": "W",
      "hidden": "data.sourceMode !== 'pv_consumption' || data.inputMode !== 'power'",
      "sm": 12,
      "md": 3
    },
    "unitConsumptionEnergy": {
      "type": "select",
      "label": "Einheit",
      "options": [ { "value": "kWh", "label": "kWh" }, { "value": "Wh", "label": "Wh" } ],
      "default": "kWh",
      "hidden": "data.sourceMode !== 'pv_consumption' || data.inputMode !== 'energy'",
      "sm": 12,
      "md": 3
    },
    "idGridImport": {
      "type": "objectId",
      "label": "Datenpunkt Netzbezug",
      "hidden": "data.sourceMode !== 'grid_meter'",
      "newLine": true,
      "sm": 12,
      "md": 5
    },
    "unitGridImportPower": {
      "type": "select",
      "label": "Einheit",
      "options": [ { "value": "W", "label": "W" }, { "value": "kW", "label": "kW" } ],
      "default": "W",
      "hidden": "data.sourceMode !== 'grid_meter' || data.inputMode !== 'power'",
      "sm": 12,
      "md": 3
    },
    "unitGridImportEnergy": {
      "type": "select",
      "label": "Einheit",
      "options": [ { "value": "kWh", "label": "kWh" }, { "value": "Wh", "label": "Wh" } ],
      "default": "kWh",
      "hidden": "data.sourceMode !== 'grid_meter' || data.inputMode !== 'energy'",
      "sm": 12,
      "md": 3
    },
    "idGridExport": {
      "type": "objectId",
      "label": "Datenpunkt Einspeisung",
      "hidden": "data.sourceMode !== 'grid_meter'",
      "newLine": true,
      "sm": 12,
      "md": 5
    },
    "unitGridExportPower": {
      "type": "select",
      "label": "Einheit",
      "options": [ { "value": "W", "label": "W" }, { "value": "kW", "label": "kW" } ],
      "default": "W",
      "hidden": "data.sourceMode !== 'grid_meter' || data.inputMode !== 'power'",
      "sm": 12,
      "md": 3
    },
    "unitGridExportEnergy": {
      "type": "select",
      "label": "Einheit",
      "options": [ { "value": "kWh", "label": "kWh" }, { "value": "Wh", "label": "Wh" } ],
      "default": "kWh",
      "hidden": "data.sourceMode !== 'grid_meter' || data.inputMode !== 'energy'",
      "sm": 12,
      "md": 3
    },
    "idGridPower": {
      "type": "objectId",
      "label": "Datenpunkt Netzleistung (mit Vorzeichen)",
      "help": "Ein einzelner Datenpunkt, der Bezug und Einspeisung über das Vorzeichen abbildet (z. B. OBIS 16.7.0 Gesamtwirkleistung).",
      "hidden": "data.sourceMode !== 'grid_signed'",
      "newLine": true,
      "sm": 12,
      "md": 5
    },
    "unitGridPowerPower": {
      "type": "select",
      "label": "Einheit",
      "options": [ { "value": "W", "label": "W" }, { "value": "kW", "label": "kW" } ],
      "default": "W",
      "hidden": "data.sourceMode !== 'grid_signed' || data.inputMode !== 'power'",
      "sm": 12,
      "md": 3
    },
    "unitGridPowerEnergy": {
      "type": "select",
      "label": "Einheit",
      "options": [ { "value": "kWh", "label": "kWh" }, { "value": "Wh", "label": "Wh" } ],
      "default": "kWh",
      "hidden": "data.sourceMode !== 'grid_signed' || data.inputMode !== 'energy'",
      "sm": 12,
      "md": 3
    },
    "gridSignPositive": {
      "type": "select",
      "label": "Vorzeichen-Bedeutung",
      "help": "Bei den meisten Zählern (OBIS 16.7.0) ist positiv = Netzbezug, negativ = Einspeisung.",
      "options": [
        { "value": "import", "label": "Positiv = Netzbezug, negativ = Einspeisung" },
        { "value": "export", "label": "Positiv = Einspeisung, negativ = Netzbezug" }
      ],
      "default": "import",
      "hidden": "data.sourceMode !== 'grid_signed'",
      "sm": 12,
      "md": 4
    },
    "intervalSec": {
      "type": "number",
      "label": "Simulationsintervall (Sekunden)",
      "min": 5,
      "default": 30,
      "newLine": true,
      "sm": 12,
      "md": 4
    },

    "_headerBattery": {
      "type": "header",
      "size": 2,
      "text": "Speicher"
    },
    "storageTemplate": {
      "type": "select",
      "label": "Speicher-Vorlage",
      "help": "Vorlage mit technischen Richtwerten wählen – die Werte sind REPRÄSENTATIV, bitte am Datenblatt prüfen. Für abweichende/eigene Werte 'Eigene Werte' wählen.",
      "options": [
        { "value": "custom", "label": "Eigene Werte (manuell)" },
        { "value": "huawei_luna2000_5", "label": "Huawei LUNA2000 – 5 kWh" },
        { "value": "huawei_luna2000_10", "label": "Huawei LUNA2000 – 10 kWh" },
        { "value": "huawei_luna2000_15", "label": "Huawei LUNA2000 – 15 kWh" },
        { "value": "huawei_luna2000_7_s1", "label": "Huawei LUNA2000 S1 – 7 kWh" },
        { "value": "huawei_luna2000_14_s1", "label": "Huawei LUNA2000 S1 – 14 kWh" },
        { "value": "huawei_luna2000_21_s1", "label": "Huawei LUNA2000 S1 – 21 kWh" },
        { "value": "byd_hvs_5_1", "label": "BYD Battery-Box HVS 5.1" },
        { "value": "byd_hvs_7_7", "label": "BYD Battery-Box HVS 7.7" },
        { "value": "byd_hvs_10_2", "label": "BYD Battery-Box HVS 10.2" },
        { "value": "tesla_powerwall_2", "label": "Tesla Powerwall 2" },
        { "value": "lg_resu10h", "label": "LG RESU10H" },
        { "value": "sonnen_10_11", "label": "sonnenBatterie 10 (11 kWh)" },
        { "value": "e3dc_s10_e_13", "label": "E3/DC S10 E (13 kWh)" }
      ],
      "default": "custom",
      "newLine": true,
      "sm": 12,
      "md": 6
    },
    "capacityKwh": {
      "type": "number",
      "label": "Kapazität (kWh)",
      "min": 0.1,
      "default": 10,
      "hidden": "data.storageTemplate !== 'custom'",
      "newLine": true,
      "sm": 12,
      "md": 4
    },
    "minSocPercent": {
      "type": "number",
      "label": "Mindest-Ladezustand (%)",
      "min": 0,
      "max": 50,
      "default": 5,
      "hidden": "data.storageTemplate !== 'custom'",
      "sm": 12,
      "md": 4
    },
    "roundTripEff": {
      "type": "number",
      "label": "Roundtrip-Wirkungsgrad (%)",
      "min": 1,
      "max": 100,
      "default": 90,
      "hidden": "data.storageTemplate !== 'custom'",
      "sm": 12,
      "md": 4
    },
    "maxChargeW": {
      "type": "number",
      "label": "Max. Ladeleistung (W)",
      "min": 0,
      "default": 3000,
      "hidden": "data.storageTemplate !== 'custom'",
      "newLine": true,
      "sm": 12,
      "md": 6
    },
    "maxDischargeW": {
      "type": "number",
      "label": "Max. Entladeleistung (W)",
      "min": 0,
      "default": 3000,
      "hidden": "data.storageTemplate !== 'custom'",
      "sm": 12,
      "md": 6
    },

    "_headerEconomics": {
      "type": "header",
      "size": 2,
      "text": "Wirtschaftlichkeit"
    },
    "priceImportCt": {
      "type": "number",
      "label": "Strompreis Bezug (ct/kWh)",
      "min": 0,
      "default": 35,
      "newLine": true,
      "sm": 12,
      "md": 4
    },
    "priceFeedInCt": {
      "type": "number",
      "label": "Einspeisevergütung (ct/kWh)",
      "min": 0,
      "default": 8,
      "sm": 12,
      "md": 4
    },
    "investmentEur": {
      "type": "number",
      "label": "Anschaffungskosten (€)",
      "min": 0,
      "default": 7000,
      "sm": 12,
      "md": 4
    },

    "_headerViz": {
      "type": "header",
      "size": 2,
      "text": "Grafische Auswertung / WebUI"
    },
    "_vizHint": {
      "type": "staticText",
      "text": "Für die Verlaufs-Diagramme werden Zeitreihen benötigt. Aktiviere dazu ein History-Logging (Adapter 'history', 'sql' oder 'influxdb') auf den live.*-Datenpunkten dieser Instanz (im Netz-Modus z. B. live.gridNetOrigW, live.gridNetSimW, live.batteryPowerW; im PV-Modus live.pvW, live.consumptionW, live.directUseW) sowie auf battery.soc.percent. Für die Monatsansicht zusätzlich economics.savingsTotal.eur. Ohne Logging zeigt die Auswertung nur den aktuellen Wert, keinen Verlauf.",
      "sm": 12
    }
  }
}
