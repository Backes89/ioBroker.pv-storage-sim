    "gridSignPositive": {
      "type": "select",
      "label": {
        "en": "Sign convention",
        "de": "Vorzeichen-Bedeutung"
      },
      "help": {
        "en": "Most meters (OBIS 16.7.0) use positive = grid import, negative = feed-in.",
        "de": "Bei den meisten Zählern (OBIS 16.7.0) ist positiv = Netzbezug, negativ = Einspeisung."
      },
      "options": [
        {
          "value": "import",
          "label": {
            "en": "Positive = import, negative = feed-in",
            "de": "Positiv = Netzbezug, negativ = Einspeisung"
          }
        },
        {
          "value": "export",
          "label": {
            "en": "Positive = feed-in, negative = import",
            "de": "Positiv = Einspeisung, negativ = Netzbezug"
          }
        }
      ],
      "default": "import",
      "hidden": "data.sourceMode !== 'grid_signed'",
      "sm": 12,
      "md": 4,
      "xs": 12,
      "lg": 4,
      "xl": 4
    },
    "readMode": {
      "type": "select",
      "label": {
        "en": "Reading mode",
        "de": "Lesemodus"
      },
      "help": {
        "en": "Polling reads the momentary value once per interval. Event-based subscribes to the source datapoints and integrates every change time-weighted (more accurate with fast-changing meters).",
        "de": "Zyklische Abfrage liest je Intervall den Momentanwert. Ereignisbasiert abonniert die Quell-Datenpunkte und integriert jede Änderung zeitgewichtet (genauer bei schnell schwankenden Zählern)."
      },
      "options": [
        {
          "value": "poll",
          "label": {
            "en": "Polling (default)",
            "de": "Zyklische Abfrage (Standard)"
          }
        },
        {
          "value": "subscribe",
          "label": {
            "en": "Event-based (subscribe)",
            "de": "Ereignisbasiert (Subscribe)"
          }
        }
      ],
      "default": "poll",
      "newLine": true,
      "sm": 12,
      "md": 5,
      "xs": 12,
      "lg": 5,
      "xl": 5
    },
    "intervalSec": {
      "type": "number",
      "label": {
        "en": "Simulation interval (seconds)",
        "de": "Simulationsintervall (Sekunden)"
      },
      "help": {
        "en": "Polling: sampling AND accounting interval. Event-based: accounting interval only (accuracy comes from the events); states/charts are updated at this pace.",
        "de": "Zyklische Abfrage: Abtast- UND Verbuchungsintervall. Ereignisbasiert: nur Verbuchungsintervall (die Genauigkeit kommt aus den Ereignissen); States/Charts werden in diesem Takt aktualisiert."
      },
      "min": 5,
      "default": 30,
      "sm": 12,
      "md": 4,
      "xs": 12,
      "lg": 4,
      "xl": 4
    },
