      "md": 3,
      "xs": 12,
      "lg": 3,
      "xl": 3
    },
    "gridSignPositive": {
      "type": "select",
      "label": "Sign convention",
      "help": "Most meters (OBIS 16.7.0) use positive = grid import, negative = feed-in.",
      "options": [
        {
          "value": "import",
          "label": "Positive = import, negative = feed-in"
        },
        {
          "value": "export",
          "label": "Positive = feed-in, negative = import"
        }
      ],
      "default": "import",
      "hidden": "data.sourceMode !== 'grid_signed'",
      "sm": 12,
      "md": 4,
      "xs": 12,
      "lg": 4,
      "xl": 4
    },
    "readMode": {
      "type": "select",
      "label": "Reading mode",
      "help": "Polling reads the momentary value once per interval. Event-based subscribes to the source datapoints and integrates every change time-weighted (more accurate with fast-changing meters).",
      "options": [
        {
          "value": "poll",
          "label": "Polling (default)"
        },
        {
          "value": "subscribe",
          "label": "Event-based (subscribe)"
        }
      ],
      "default": "poll",
      "newLine": true,
      "sm": 12,
      "md": 5,
      "xs": 12,
      "lg": 5,
      "xl": 5
    },
    "intervalSec": {
      "type": "number",
      "label": "Simulation interval (seconds)",
      "help": "Polling: sampling AND accounting interval. Event-based: accounting interval only (accuracy comes from the events); states/charts are updated at this pace.",
      "min": 5,
      "default": 30,
      "sm": 12,
      "md": 4,
      "xs": 12,
      "lg": 4,
      "xl": 4
    },
