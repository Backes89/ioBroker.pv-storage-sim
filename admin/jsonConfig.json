{
  "i18n": true,
  "type": "panel",
  "items": {
    "_headerInput": {
      "type": "header",
      "size": 2,
      "text": "Input data"
    },
    "inputMode": {
      "type": "select",
      "label": "Input type of the datapoints",
      "help": "Power: momentary values in W. Meter reading: cumulative values in kWh.",
      "options": [
        {
          "value": "power",
          "label": "Power (W, momentary)"
        },
        {
          "value": "energy",
          "label": "Meter reading (kWh, cumulative)"
        }
      ],
      "default": "power",
      "newLine": true,
      "sm": 12,
      "md": 6,
      "xs": 12,
      "lg": 6,
      "xl": 6
    },
    "sourceMode": {
      "type": "select",
      "label": "Data source",
      "help": "PV + consumption OR grid import + feed-in of a bidirectional meter.",
      "options": [
        {
          "value": "pv_consumption",
          "label": "PV generation + house consumption"
        },
        {
          "value": "grid_meter",
          "label": "Grid import + feed-in (two datapoints)"
        },
        {
          "value": "grid_signed",
          "label": "Grid – one signed datapoint (+/-)"
        }
      ],
      "default": "pv_consumption",
      "sm": 12,
      "md": 6,
      "xs": 12,
      "lg": 6,
      "xl": 6
    },
    "idPv": {
      "type": "objectId",
      "label": "PV generation datapoint",
      "hidden": "data.sourceMode !== 'pv_consumption'",
      "newLine": true,
      "sm": 12,
      "md": 5,
      "xs": 12,
      "lg": 5,
      "xl": 5
    },
    "unitPvPower": {
      "type": "select",
      "label": "Unit",
      "options": [
        {
          "value": "W",
          "label": "W"
        },
        {
          "value": "kW",
          "label": "kW"
        }
      ],
      "default": "W",
      "hidden": "data.sourceMode !== 'pv_consumption' || data.inputMode !== 'power'",
      "sm": 12,
      "md": 3,
      "xs": 12,
      "lg": 3,
      "xl": 3
    },
    "unitPvEnergy": {
      "type": "select",
      "label": "Unit",
      "options": [
        {
          "value": "kWh",
